generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model acoes_ia {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id        String          @db.Uuid
  conta_id          String?         @db.Uuid
  titulo            String
  racional          String?
  tipo              String?
  urgencia          String?         @default("media")
  comando_api       String?
  entidade_tipo     String?
  entidade_id       String?
  valor_antes       Json?
  valor_depois      Json?
  economia_estimada String?
  status            String?         @default("pendente")
  aprovada_por      String?
  executada_em      DateTime?       @db.Timestamptz(6)
  revertida_em      DateTime?       @db.Timestamptz(6)
  rollback_ate      DateTime?       @db.Timestamptz(6)
  erro_execucao     String?
  criado_em         DateTime?       @default(now()) @db.Timestamptz(6)
  clientes          clientes        @relation(fields: [cliente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contas_anuncio    contas_anuncio? @relation(fields: [conta_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  audit_log         audit_log[]

  @@index([cliente_id, status], map: "idx_acoes_cliente_status")
}

model anuncios {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conjunto_id        String             @db.Uuid
  ad_id_externo      String
  nome               String?
  formato            String?
  titulo             String?
  status             String?            @default("active")
  thumbnail_url      String?
  atualizado_em      DateTime?          @default(now()) @db.Timestamptz(6)
  conjuntos_anuncios conjuntos_anuncios @relation(fields: [conjunto_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model audit_log {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id    String?   @db.Uuid
  acao_id       String?   @db.Uuid
  tipo          String
  descricao     String
  entidade_tipo String?
  entidade_id   String?
  valor_antes   Json?
  valor_depois  Json?
  executado_por String?   @default("sistema")
  ip_origem     String?
  criado_em     DateTime? @default(now()) @db.Timestamptz(6)
  acoes_ia      acoes_ia? @relation(fields: [acao_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  clientes      clientes? @relation(fields: [cliente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([cliente_id, criado_em(sort: Desc)], map: "idx_audit_cliente")
}

model campanhas {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conta_id            String               @db.Uuid
  campanha_id_externo String
  nome                String?
  objetivo            String?
  status              String?              @default("active")
  budget_diario       Decimal?             @db.Decimal(10, 2)
  budget_total        Decimal?             @db.Decimal(10, 2)
  data_inicio         DateTime?            @db.Date
  data_fim            DateTime?            @db.Date
  atualizado_em       DateTime?            @default(now()) @db.Timestamptz(6)
  contas_anuncio      contas_anuncio       @relation(fields: [conta_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  conjuntos_anuncios  conjuntos_anuncios[]
}

model clientes {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome           String
  slug           String           @unique
  logo_url       String?
  cor_primaria   String?          @default("#00D68F")
  plano          String?          @default("starter")
  ativo          Boolean?         @default(true)
  criado_em      DateTime?        @default(now()) @db.Timestamptz(6)
  atualizado_em  DateTime?        @default(now()) @db.Timestamptz(6)
  acoes_ia       acoes_ia[]
  audit_log      audit_log[]
  configuracoes  configuracoes?
  contas_anuncio contas_anuncio[]
  leads          leads[]
  notificacoes   notificacoes[]
  orcamentos     orcamentos[]
  workflows      workflows[]
}

model configuracoes {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id               String    @unique @db.Uuid
  ajuste_max_budget_pct    Decimal?  @default(30) @db.Decimal(5, 2)
  limite_gasto_diario      Decimal?  @db.Decimal(12, 2)
  janela_rollback_horas    Int?      @default(2)
  notif_slack_webhook      String?
  notif_whatsapp_numero    String?
  notif_email              String?
  fonte_investimento       String?   @default("plataforma")
  fonte_leads              String?   @default("plataforma")
  fonte_leads_qualificados String?   @default("crm")
  fonte_receita            String?   @default("crm")
  crm_tipo                 String?
  crm_webhook_url          String?
  criado_em                DateTime? @default(now()) @db.Timestamptz(6)
  atualizado_em            DateTime? @default(now()) @db.Timestamptz(6)
  clientes                 clientes  @relation(fields: [cliente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model conjuntos_anuncios {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campanha_id      String     @db.Uuid
  adset_id_externo String
  nome             String?
  audiencia        String?
  status           String?    @default("active")
  budget_diario    Decimal?   @db.Decimal(10, 2)
  atualizado_em    DateTime?  @default(now()) @db.Timestamptz(6)
  anuncios         anuncios[]
  campanhas        campanhas  @relation(fields: [campanha_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model contas_anuncio {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id         String             @db.Uuid
  nome               String
  plataforma         String
  account_id_externo String?
  cpl_meta           Decimal?           @db.Decimal(10, 2)
  cpl_max            Decimal?           @db.Decimal(10, 2)
  cac_max            Decimal?           @db.Decimal(10, 2)
  roas_meta          Decimal?           @db.Decimal(6, 2)
  frequencia_max     Decimal?           @db.Decimal(4, 1)
  ctr_minimo         Decimal?           @db.Decimal(5, 2)
  ativa              Boolean?           @default(true)
  criado_em          DateTime?          @default(now()) @db.Timestamptz(6)
  acoes_ia           acoes_ia[]
  campanhas          campanhas[]
  clientes           clientes           @relation(fields: [cliente_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  metricas_diarias   metricas_diarias[]
  orcamentos         orcamentos[]
  snapshots          snapshots[]
}

model leads {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id      String    @db.Uuid
  lead_id_externo String?
  nome            String?
  email           String?
  telefone        String?
  utm_source      String?
  utm_medium      String?
  utm_campaign    String?
  utm_adset       String?
  utm_ad          String?
  utm_content     String?
  status          String?   @default("novo")
  qualificado     Boolean?  @default(false)
  vendido         Boolean?  @default(false)
  valor_venda     Decimal?  @db.Decimal(12, 2)
  motivo_perda    String?
  data_criacao    DateTime? @db.Date
  data_qualif     DateTime? @db.Date
  data_venda      DateTime? @db.Date
  criado_em       DateTime? @default(now()) @db.Timestamptz(6)
  atualizado_em   DateTime? @default(now()) @db.Timestamptz(6)
  clientes        clientes  @relation(fields: [cliente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([cliente_id], map: "idx_leads_cliente")
  @@index([status], map: "idx_leads_status")
  @@index([utm_campaign], map: "idx_leads_utm_campaign")
}

model metricas_diarias {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conta_id         String         @db.Uuid
  campanha_id      String?
  adset_id         String?
  ad_id            String?
  data             DateTime       @db.Date
  investimento     Decimal?       @default(0) @db.Decimal(12, 2)
  impressoes       Int?           @default(0)
  cliques          Int?           @default(0)
  leads_plataforma Int?           @default(0)
  cpm              Decimal?       @db.Decimal(10, 2)
  ctr              Decimal?       @db.Decimal(8, 4)
  cpl_plataforma   Decimal?       @db.Decimal(10, 2)
  frequencia       Decimal?       @db.Decimal(6, 2)
  alcance          Int?           @default(0)
  visualizacoes    Int?           @default(0)
  criado_em        DateTime?      @default(now()) @db.Timestamptz(6)
  contas_anuncio   contas_anuncio @relation(fields: [conta_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([conta_id, ad_id, data])
  @@index([conta_id, data(sort: Desc)], map: "idx_metricas_conta_data")
  @@index([data(sort: Desc)], map: "idx_metricas_data")
}

model notificacoes {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id String?   @db.Uuid
  tipo       String?   @default("info")
  titulo     String
  mensagem   String?
  lida       Boolean?  @default(false)
  acao_url   String?
  criado_em  DateTime? @default(now()) @db.Timestamptz(6)
  clientes   clientes? @relation(fields: [cliente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([cliente_id, lida, criado_em(sort: Desc)], map: "idx_notif_cliente_lida")
}

model orcamentos {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id      String          @db.Uuid
  conta_id        String?         @db.Uuid
  periodo_inicio  DateTime        @db.Date
  periodo_fim     DateTime        @db.Date
  tipo            String?         @default("mensal")
  valor_planejado Decimal?        @db.Decimal(12, 2)
  valor_gasto     Decimal?        @default(0) @db.Decimal(12, 2)
  valor_reserva   Decimal?        @default(0) @db.Decimal(12, 2)
  observacao      String?
  criado_em       DateTime?       @default(now()) @db.Timestamptz(6)
  clientes        clientes        @relation(fields: [cliente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contas_anuncio  contas_anuncio? @relation(fields: [conta_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model snapshots {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conta_id           String         @db.Uuid
  data               DateTime       @db.Date
  investimento_total Decimal?       @db.Decimal(12, 2)
  leads_plataforma   Int?
  leads_crm          Int?
  leads_qualificados Int?
  vendas             Int?
  cpl_plataforma     Decimal?       @db.Decimal(10, 2)
  cpl_crm            Decimal?       @db.Decimal(10, 2)
  cac                Decimal?       @db.Decimal(10, 2)
  receita            Decimal?       @db.Decimal(12, 2)
  roas               Decimal?       @db.Decimal(8, 2)
  ctr_medio          Decimal?       @db.Decimal(8, 4)
  cpm_medio          Decimal?       @db.Decimal(10, 2)
  frequencia_media   Decimal?       @db.Decimal(6, 2)
  taxa_qualificacao  Decimal?       @db.Decimal(6, 4)
  criado_em          DateTime?      @default(now()) @db.Timestamptz(6)
  contas_anuncio     contas_anuncio @relation(fields: [conta_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([conta_id, data])
  @@index([conta_id, data(sort: Desc)], map: "idx_snapshots_conta_data")
}

model workflows {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id       String?   @db.Uuid
  nome             String
  descricao        String?
  tipo             String?
  ativo            Boolean?  @default(true)
  schedule         String?
  ultima_execucao  DateTime? @db.Timestamptz(6)
  proxima_execucao DateTime? @db.Timestamptz(6)
  total_execucoes  Int?      @default(0)
  criado_em        DateTime? @default(now()) @db.Timestamptz(6)
  clientes         clientes? @relation(fields: [cliente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
